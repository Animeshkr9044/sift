# Environment variables
.env

# Virtual environments
venv/
.venv/

# Python cache
__pycache__/
*.pyc

# Generated reports and data
# Ignore all contents of the output directory by default
output/*

# But do not ignore the PDF files inside it
!output/**/*.pdf

# And do not ignore the directory itself, so Git can track the PDFs
!output/

# Databases
data/*.db

